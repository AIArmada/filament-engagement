{
    "name": "aiarmada/filament-engagement",
    "description": "Filament admin for aiarmada/engagement: manage follows, bookmarks, responses, reactions, subscriptions, reminders.",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "aiarmada/commerce-support": "self.version",
        "aiarmada/engagement": "self.version",
        "filament/filament": "^5.6.7"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentEngagement\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentEngagement\\FilamentEngagementServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
